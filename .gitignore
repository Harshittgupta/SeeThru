# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*
dist/
build/
coverage/

# Environment / secrets
.env
.env.local
.env.*.local

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

